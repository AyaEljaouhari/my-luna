<node name="rtabmap" pkg="rtabmap_slam" type="rtabmap" output="screen">
  <param name="frame_id" value="base_link"/>
  <param name="odom_frame_id" value="luna/odom"/>   <!-- This must exist in your tf tree -->
  <param name="map_frame_id" value="map"/>
  <param name="subscribe_depth" value="false"/>
  <param name="subscribe_stereo" value="false"/>
  <param name="subscribe_rgb" value="true"/>
  <param name="subscribe_odom_info" value="true"/>
  <param name="approx_sync" value="true"/>
  <param name="image_transport" value="compressed"/>

  <!-- Topic remapping -->
  <remap from="rgb/image" to="/luna/camera_node/image"/>
  <remap from="rgb/camera_info" to="/luna/camera_node/camera_info"/>
  <remap from="odom" to="/luna/velocity_to_pose_node/pose"/>
</node>
